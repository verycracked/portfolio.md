generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String          @id @default(cuid())
  slug          String          @unique
  title         String
  description   String          @default("")
  body          String          @default("")
  heroImageUrl  String?
  sourceUrl     String?
  // HMAC hash of the visitor password. null = public. owner always has access.
  passwordHash  String?
  order         Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  images        ProjectImage[]
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// Singleton site settings. id is always "main".
model Settings {
  id        String   @id
  avatarUrl String?
  updatedAt DateTime @updatedAt
}

// Long-lived bearer tokens for the snapshot Chrome extension (and any other
// external clients that talk to portfolio.md). The plaintext token is shown
// once when minted; we store only the SHA-256 hash.
model ExtensionToken {
  id         String    @id @default(cuid())
  label      String    @default("Snapshot extension")
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revoked    Boolean   @default(false)
}

model Project {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
}

model Asset {
  id        String   @id @default(cuid())
  url       String
  key       String   @unique
  mime      String
  size      Int
  createdAt DateTime @default(now())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  @@index([projectId])
}
