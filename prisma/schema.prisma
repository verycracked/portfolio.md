generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A curated *version* of the portfolio at a shareable URL like `/v/[slug]`.
// Each view owns its own copy of the homepage content (markdown intro,
// gallery sections, tile arrangement) so edits in one view don't bleed
// into another or into the main `/` page. A fresh view is seeded with a
// snapshot of `/` so the owner has a starting point to mutate.
model View {
  id           String   @id @default(cuid())
  // URL slug — `/v/<slug>` resolves to this view. Kept distinct from
  // `name` so the owner can rename without breaking shared links.
  slug         String   @unique
  // Owner-facing label, e.g. "Hiring managers" or "Friends".
  name         String
  // Optional one-liner for the share-banner at the top of the public
  // view. Lets the owner say hi to whoever they shared the link with.
  greeting     String   @default("")
  // Per-view markdown intro — mirrors the human.md document the main
  // page renders, but isolated so each view can have its own copy.
  aboutBody    String   @default("")
  // Toggle the about section + the gallery section in the rendered view.
  showAbout    Boolean  @default(true)
  showProjects Boolean  @default(true)
  // LEGACY filter fields from the previous filter-only design. New views
  // ignore these; the per-view groups + projects tables drive content.
  // Kept on the row so existing rows continue to load.
  projectIds   Json     @default("[]")
  groupIds     Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  groups       ViewGroup[]
  projects     ViewProject[]

  @@index([slug])
}

// Per-view gallery section — sibling of Group but scoped to a single view.
model ViewGroup {
  id        String        @id @default(cuid())
  viewId    String
  view      View          @relation(fields: [viewId], references: [id], onDelete: Cascade)
  slug      String
  name      String
  linkUrl   String        @default("")
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  projects  ViewProject[]

  @@unique([viewId, slug])
  @@index([viewId])
}

// Per-view project tile. Mirrors the fields the homepage gallery reads
// from `Project`, so the Gallery component can render either source with
// the same shape. `sourceProjectId` is an optional pointer to the
// canonical Project this row was seeded from — used so clicking a view
// tile can still deep-link to the canonical /projects/[slug] detail
// page. Tiles created directly inside a view (no seed origin) leave
// sourceProjectId null.
model ViewProject {
  id              String     @id @default(cuid())
  viewId          String
  view            View       @relation(fields: [viewId], references: [id], onDelete: Cascade)
  viewGroupId     String?
  viewGroup       ViewGroup? @relation(fields: [viewGroupId], references: [id], onDelete: SetNull)
  sourceProjectId String?
  sourceProject   Project?   @relation("ViewProjectSource", fields: [sourceProjectId], references: [id], onDelete: SetNull)
  // Self-relation for sub-projects within a view (mirrors Project.parentId).
  parentId        String?
  parent          ViewProject?  @relation("ViewProjectChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children        ViewProject[] @relation("ViewProjectChildren")

  slug         String
  title        String
  description  String  @default("")
  sourceUrl    String?
  heroImageUrl String?
  posterUrl    String?
  heroOffsetY  Float   @default(50)
  hasAudio     Boolean @default(false)
  isOpenable   Boolean @default(false)
  colSpan      Int     @default(6)
  rowSpan      Int     @default(6)
  order        Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([viewId, slug])
  @@index([viewId])
  @@index([viewGroupId])
  @@index([sourceProjectId])
  @@index([parentId])
}

// A named group of project tiles on the homepage gallery, e.g. "CodeRabbit",
// "Trustlists". Every project belongs to exactly one group; we always have at
// least the auto-seeded "Untitled" group available as a default home for
// brand-new uploads.
model Group {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  // Optional URL rendered as a small link next to the section name.
  linkUrl   String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects  Project[]
}

model Project {
  id            String          @id @default(cuid())
  slug          String          @unique
  title         String
  description   String          @default("")
  // DEPRECATED: legacy project-level content. After surfaces shipped, content
  // lives on Surface.body / Surface.heroImageUrl. Kept here as a non-breaking
  // fallback for the public page until everything is migrated.
  body          String          @default("")
  heroImageUrl  String?
  // Optional still extracted from the hero (when it's a video) at upload
  // time. Used as the <video poster> attribute and as the standalone image
  // on touch devices where we don't autoplay.
  posterUrl     String?
  // 0–100 — vertical framing for the cover image on the project detail
  // page. 0 = top of the image is shown, 100 = bottom, 50 = centered.
  // The image is always rendered at a fixed 16:10 aspect with
  // object-cover, so any extra height in the source is panned via this.
  heroOffsetY   Float           @default(50)
  // True when the hero video has meaningful audio worth surfacing — gates
  // the on-tile "Play" CTA and the theater modal entry point. Defaults to
  // false so silent screen recordings stay calm (hover preview only).
  hasAudio      Boolean         @default(false)
  // Opt-in: visitor card on the homepage becomes a link to the project's
  // detail page even when it has no children. Useful for stand-alone
  // projects that have a meaningful write-up but no sub-projects.
  isOpenable    Boolean         @default(false)
  sourceUrl     String?
  // HMAC hash of the visitor password. null = public. owner always has access.
  passwordHash  String?
  // Order *within* the project's group on the homepage gallery.
  order         Int             @default(0)
  // Bento-grid sizing on the portfolio page. colSpan is the number of
  // 4-column grid cells the card occupies horizontally (1–4); rowSpan is
  // the same vertically (1–2). Both default to 1 so existing projects keep
  // the standard square cell.
  colSpan       Int             @default(1)
  rowSpan       Int             @default(1)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  // Section this tile lives in. Nullable on the column so the backfill can
  // run before any group exists; in practice every row gets pointed at the
  // default group during migration and the API never accepts null.
  groupId       String?
  group         Group?          @relation(fields: [groupId], references: [id])
  // Optional parent project — when set, this row is a sub-project that
  // lives on its parent's detail page rather than on the homepage gallery.
  // Self-referential so any depth of nesting is supported; in practice we
  // only render one level deep per page.
  parentId      String?
  parent        Project?        @relation("ProjectChildren", fields: [parentId], references: [id])
  children      Project[]       @relation("ProjectChildren")
  images        ProjectImage[]
  assets        Asset[]
  surfaces      Surface[]
  // Inverse of ViewProject.sourceProject — rows in any View that point
  // back at this canonical Project as their seed origin.
  viewMirrors   ViewProject[] @relation("ViewProjectSource")

  @@index([groupId])
  @@index([parentId])
}

// A "product surface" is a tab inside a project: e.g. Web, Mobile, Marketing.
// Each surface owns its own hero, body, and gallery of images. Order is the
// left-to-right tab order; slug is unique within the parent project.
model Surface {
  id           String         @id @default(cuid())
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slug         String
  name         String
  // Short blurb shown under the h1 on this surface's detail page.
  // Separate from `body` (which is the long-form markdown).
  description  String         @default("")
  body         String         @default("")
  heroImageUrl String?
  order        Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  images       ProjectImage[]

  @@unique([projectId, slug])
  @@index([projectId])
}

model ProjectImage {
  id        String   @id @default(cuid())
  // projectId is denormalized so we can keep cascade-on-project-delete cheap
  // and continue to filter by project quickly. surfaceId is the source of
  // truth for which tab the image renders under.
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  surfaceId String
  surface   Surface  @relation(fields: [surfaceId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([surfaceId])
}

// Singleton site settings. id is always "main".
model Settings {
  id        String   @id
  avatarUrl String?
  updatedAt DateTime @updatedAt
}

// Editable nomo-style markdown documents (e.g., the homepage at slug="home",
// the cv at slug="cv"). Body holds the raw source — frontmatter included.
// When no row exists for a slug, `readNomoDocument` falls back to the seed
// file at `content/<slug>.md`. Owners edit via /api/pages/[slug].
model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  body      String
  updatedAt DateTime @updatedAt
}

// Long-lived bearer tokens for the snapshot Chrome extension (and any other
// external clients that talk to portfolio.md). The plaintext token is shown
// once when minted; we store only the SHA-256 hash.
model ExtensionToken {
  id         String    @id @default(cuid())
  label      String    @default("Snapshot extension")
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revoked    Boolean   @default(false)
}

model Asset {
  id        String   @id @default(cuid())
  url       String
  key       String   @unique
  mime      String
  size      Int
  createdAt DateTime @default(now())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  @@index([projectId])
}
