# Copy to ~/.claude/skills/portfolio/config.env and fill in.
# This file is read by the `portfolio` skill on every invocation.

# Base URL of the deployed portfolio.md app. No trailing slash.
# Use http://localhost:3001 when testing against a local dev server.
PORTFOLIO_URL=

# Same value as OWNER_PASSWORD on the deploy. Used to obtain a session cookie.
OWNER_PASSWORD=

# Optional. If set, the skill reports the public URL as $PORTFOLIO_URL/$OWNER_USERNAME.
OWNER_USERNAME=
